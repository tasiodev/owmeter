generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js (NextAuth v5) required models ────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  falsePositiveReports         FalsePositiveReport[] @relation("FalsePositiveReporter")
  falsePositiveReviewsDone     FalsePositiveReport[] @relation("FalsePositiveReviewer")
  githubInstallation           GitHubInstallation?
  bannedAt      DateTime?
  createdAt     DateTime  @default(now())
}

model Project {
  id   String      @id @default(cuid())
  type ProjectType @default(WEBSITE)
  name String
  falsePositiveReports FalsePositiveReport[]

  // ── Domain ownership (WEBSITE type) ──────────────────────────────────────
  domain             String?
  verified           Boolean             @default(false)
  verificationToken  String              @unique @default(cuid())
  verificationMethod VerificationMethod?
  verifiedAt         DateTime?

  // ── Repository ownership (WEBSITE optional / CODE_REPO required) ──────────
  repoUrl                  String?
  repoVerified             Boolean  @default(false)
  repoVerificationToken    String?  @unique @default(cuid())
  repoVerifiedAt           DateTime?

  // ── GitHub App private repo (optional) ───────────────────────────────────
  githubInstallationNumericId  Int?      // GitHub's numeric installation ID (used to generate access tokens)
  githubRepoFullName           String?   // "owner/repo"

  // Visibility
  isPublic  Boolean  @default(true)

  // CI/CD integration
  apiKey    String  @unique @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans     Scan[]
  createdAt DateTime @default(now())

  @@unique([domain, userId])
}

model Scan {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      ScanStatus @default(PENDING)
  type        ScanType   @default(PASSIVE)
  score       Int?
  maxScore    Int?
  inRanking   Boolean    @default(false)
  errorMessage String?   @db.Text
  findings    Finding[]
  startedAt   DateTime   @default(now())
  completedAt DateTime?
}

model Finding {
  id          String        @id @default(cuid())
  scanId      String
  scan        Scan          @relation(fields: [scanId], references: [id], onDelete: Cascade)
  category    OWASPCategory
  severity    Severity
  title       String
  description String        @db.Text
  evidence    String?       @db.Text
  pointsLost  Int           @default(0)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProjectType {
  WEBSITE
  CODE_REPO
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  INVALID
}

enum ScanType {
  PASSIVE
  FULL
  CODE
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OWASPCategory {
  A01_BROKEN_ACCESS_CONTROL
  A02_SECURITY_MISCONFIGURATION
  A03_SUPPLY_CHAIN_FAILURES
  A04_CRYPTOGRAPHIC_FAILURES
  A05_INJECTION
  A06_INSECURE_DESIGN
  A07_AUTH_FAILURES
  A08_DATA_INTEGRITY_FAILURES
  A09_LOGGING_FAILURES
  A10_EXCEPTIONAL_CONDITIONS
}

enum VerificationMethod {
  DNS_TXT
  META_TAG
  FILE
}

model FalsePositiveReport {
  id           String                @id @default(cuid())
  projectId    String
  project      Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportedById String
  reportedBy   User                  @relation("FalsePositiveReporter", fields: [reportedById], references: [id], onDelete: Cascade)

  category     OWASPCategory
  title        String
  filePath     String                @default("")
  evidence     String                @db.Text
  reason       String                @db.Text

  status       FalsePositiveStatus   @default(PENDING)
  reviewedById String?
  reviewedBy   User?                 @relation("FalsePositiveReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  adminNote    String?               @db.Text

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([projectId, category, title, filePath])
}

enum FalsePositiveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── GitHub App integration ───────────────────────────────────────────────────

model GitHubInstallation {
  id             String    @id @default(cuid())
  userId         String    @unique            // one installation per user (V1)
  installationId Int       @unique            // GitHub's numeric installation ID
  targetType     String                       // "User" or "Organization"
  targetLogin    String                       // GitHub username or org name
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
