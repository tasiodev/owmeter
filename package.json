    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "bullmq": "^5.76.6",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.2",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
